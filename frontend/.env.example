# 数据库配置（占位示例）
DATABASE_URL=postgresql://rsod_admin:your_password_here@localhost:5432/rsod_agent

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rsod-images
MINIO_SECURE=false

# JWT 认证（生产环境务必修改）
JWT_SECRET_KEY=change_this_in_production_please
JWT_ALGORITHM=HS256

# 应用配置
DEBUG=true